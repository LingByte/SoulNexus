# ===========================================================================
# SoulNexus VoiceServer (.env-voice)
# ---------------------------------------------------------------------------
# Loaded by `cmd/voice` from `.env-voice`, then `.env-voice.${APP_ENV|MODE}`.
# Anything not set here falls back to the process environment, then to the
# defaults declared in `internal/config/voice.go`.
#
# Validation runs on boot — see `(*VoiceServerConfig).Validate()`.
# ===========================================================================

# --- Mode ------------------------------------------------------------------
APP_ENV=development
MODE=development

# --- Logging ---------------------------------------------------------------
# VOICE_LOG_LEVEL=info
# VOICE_LOG_FILENAME=./logs/voice.log
# VOICE_LOG_MAX_SIZE=100
# VOICE_LOG_MAX_AGE=30
# VOICE_LOG_MAX_BACKUPS=5
# VOICE_LOG_DAILY=true

# ---------------------------------------------------------------------------
# 1) SIP signaling + RTP media (transport: SIP)
# ---------------------------------------------------------------------------
VOICE_SIP_ADDR=127.0.0.1:5060
VOICE_LOCAL_IP=127.0.0.1
VOICE_RTP_START=30000
VOICE_RTP_END=30100
# Optional outbound (B-leg) target. Leave empty to disable outbound dialer.
# VOICE_OUTBOUND_URI=sip:agent@127.0.0.1:5070
# VOICE_OUTBOUND_HOLD=15s

# ---------------------------------------------------------------------------
# 2) HTTP listener (shared by xiaozhi / webrtc / sfu / hardware transports)
# ---------------------------------------------------------------------------
# Set empty to disable the HTTP listener entirely (SIP-only deployment).
VOICE_HTTP_ADDR=127.0.0.1:7080

# Dialog plane WebSocket. Required when EnableXiaozhi or EnableWebRTC = true.
VOICE_DIALOG_WS=ws://localhost:7072/ws/call
VOICE_DIALOG_RECONNECT=3
VOICE_DIALOG_RECONNECT_BACKOFF=1s
VOICE_TTS_PREWARM=true
# Low-latency TTS segmentation on voice plane (tts.stream path; LingEchoX-aligned)
# VOICE_TTS_FIRST_MIN_CHARS=2
# VOICE_TTS_FIRST_MAX_CHARS=12
# VOICE_TTS_REST_FORCE_MAX_CHARS=120
# VOICE_TTS_PREFETCH_MAX=3

# ---------------------------------------------------------------------------
# 3) Transport switches
# ---------------------------------------------------------------------------
# (a) xiaozhi WebSocket — generic device protocol
VOICE_ENABLE_XIAOZHI=true
VOICE_XIAOZHI_WS_PATH=/xiaozhi/v1/
# XIAOZHIMODE=pipeline   — ASR + VOICE_DIALOG_WS (LLM) + TTS (default)
# XIAOZHIMODE=realtime  — pkg/realtime multimodal (e.g. Qwen-Omni); no dialog WS
XIAOZHIMODE=pipeline
# New ESP32 firmware may connect directly to VOICE_XIAOZHI_WS_PATH with only
# header Device-Id (no ?payload=). When VOICE_SOULNEXUS_HW_BINDING_URL is set,
# cmd/voice auto-calls the binding API — same as /voice/lingecho/v1/.

# (b) WebRTC (browser / mobile)
VOICE_ENABLE_WEBRTC=true
# VOICE_WEBRTC_HTTP_PATH=/webrtc/v1/offer

# (c) SFU multi-party (web-side rooms). Off by default.
VOICE_ENABLE_SFU=false
VOICE_SFU_WS_PATH=/sfu/v1/ws
# VOICE_SFU_SECRET=replace-me           # required unless VOICE_SFU_ALLOW_ANON=true
VOICE_SFU_ALLOW_ANON=true               # local dev convenience
VOICE_SFU_MAX_PARTICIPANTS=16
VOICE_SFU_MAX_ROOMS=1024
# VOICE_SFU_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:7080
# VOICE_SFU_TOKEN_ADMIN_SECRET=
VOICE_SFU_RECORD=false
VOICE_SFU_RECORD_BUCKET=sfu-recordings
# VOICE_SFU_WEBHOOK_URL=

# (d) Legacy SoulNexus hardware (ESP32) WS bridge.
#     Leave VOICE_SOULNEXUS_HW_WS_PATH empty to disable.
VOICE_SOULNEXUS_HW_WS_PATH=/voice/lingecho/v1/
VOICE_SOULNEXUS_HW_BINDING_URL=http://localhost:7072/api/voice/lingecho/binding
# VOICE_SOULNEXUS_HW_BINDING_SECRET=

# ---------------------------------------------------------------------------
# 5) Dialog bridge behavior
# ---------------------------------------------------------------------------
VOICE_ASR_ECHO=false                    # echo ASR text back as TTS (debug)
VOICE_REPLY_TEXT=您好，已收到
VOICE_TTS_PREWARM=true
# Max concurrent TTS synthesizer calls (volcengine WS quota); default 1.
# VOICE_TTS_SYNTH_MAX=1
# Max concurrent segment prefetches; default 1 (prefetch runs when a segment is about to play).
# VOICE_TTS_PREFETCH_MAX=1

VOICE_BARGE_IN=true
VOICE_BARGE_IN_THRESHOLD=4500
VOICE_BARGE_IN_FRAMES=5
VOICE_DENOISE=false

VOICE_ASR_SENTENCE_FILTER=false
VOICE_ASR_SENTENCE_FILTER_SIMILARITY=0.85   # range [0, 1]

VOICE_HOLD_MESSAGES=scripts/hold/hold_messages.json

# ---------------------------------------------------------------------------
# 6) Persistence (shared DB_DRIVER + DSN with main / auth services)
# ---------------------------------------------------------------------------
# Set DSN=off (or none) to disable voice persistence entirely.
DB_DRIVER=sqlite
DSN=voiceserver.db

# ---------------------------------------------------------------------------
# 7a) Realtime multimodal (XIAOZHIMODE=realtime only)
# ---------------------------------------------------------------------------
# DashScope Qwen-Omni realtime — https://help.aliyun.com/model-studio/qwen-omni-realtime
# REALTIME_PROVIDER=aliyun_omni
# REALTIME_API_KEY=
# REALTIME_MODEL=qwen3-omni-flash-realtime
# REALTIME_VOICE=Cherry
# REALTIME_INSTRUCTIONS=你是一个友好的语音助手，请用简洁口语回答。
# REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# REALTIME_INPUT_SAMPLE_RATE=16000
# REALTIME_OUTPUT_SAMPLE_RATE=24000
# REALTIME_TEMPERATURE=0.8
# REALTIME_DIAL_TIMEOUT_MS=10000
#
# Cloud server VAD (barge-in / end-of-turn). Unset = less sensitive defaults
# (threshold 0.75, silence 1000 ms). Raise threshold or silence if noise
# triggers false interrupts; lower threshold if the device rarely detects speech.
# REALTIME_VAD_TYPE=server_vad
# REALTIME_VAD_THRESHOLD=0.75
# REALTIME_VAD_SILENCE_DURATION_MS=1000
# REALTIME_VAD_PREFIX_PADDING_MS=300
# REALTIME_VAD_INTERRUPT_RESPONSE=true
# REALTIME_VAD_CREATE_RESPONSE=true

# ---------------------------------------------------------------------------
# 7) ASR / TTS credentials (pipeline xiaozhi / WebRTC / SIP)
# ---------------------------------------------------------------------------
# cmd/voice does the audio<->text conversion itself; the business backend
# (cmd/server /ws/call) only handles the LLM dialog plane and does NOT push
# credentials over the WebSocket. If these are missing:
#   - xiaozhi & WebRTC transports are silently disabled (404 on their paths,
#     boot log shows "xiaozhi=false transports=0")
#   - SIP calls fail per-call with "missing ASR_APPID/..." in the call log
#
# LoadModuleEnvs only reads .env-voice* — root .env is NOT auto-loaded.
# Either set them here, or export them in your shell / docker env_file.
#
# Tencent QCloud ASR (https://console.cloud.tencent.com/asr)
ASR_APPID=
ASR_SECRET_ID=
ASR_SECRET_KEY=
ASR_MODEL_TYPE=8k_zh        # 8k_zh | 16k_zh | 16k_en | ...

# Tencent QCloud TTS (https://console.cloud.tencent.com/tts)
TTS_APPID=
TTS_SECRET_ID=
TTS_SECRET_KEY=

# ---------------------------------------------------------------------------
# 8) WebRTC NAT / firewall (only needed if VOICE_ENABLE_WEBRTC=true)
# ---------------------------------------------------------------------------
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
# WEBRTC_PUBLIC_IPS=          # comma-separated public IPs for 1:1-NAT hosts
# WEBRTC_UDP_PORT=            # single-port mux (default = ephemeral range)
WEBRTC_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:7080


STORAGE_KIND=qiniu
STORAGE_BUCKET=default
# 七牛云存储配置
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=cetide
QINIU_DOMAIN=https://cdn.lingecho.com
QINIU_PRIVATE=false
QINIU_REGION=huanan

COS_REGION=ap-chengdu
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET_NAME=

OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=cetide

# MinIO存储配置
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=
MINIO_PUBLIC_BASE=