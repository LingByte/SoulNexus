# Copy to .env and fill in real values — NEVER commit secrets.
#
# Realm is an arbitrary string; browsers and voiceserver only need it
# to match between credential generation and allocation time.
TURN_REALM=voiceserver.local

# Long-term credential pair. Must match what voiceserver sends to the
# browser via WEBRTC_TURN_USERNAME / WEBRTC_TURN_CREDENTIAL.
TURN_USER=voiceserver
TURN_PASSWORD=please-change-me-to-a-long-random-string

# Public reachable IPv4 of the coturn host. On a cloud VM this is the
# elastic IP; on a home setup it's your router's WAN IP (with UDP/3478
# + 49160-49200 port-forwarded to this machine).
EXTERNAL_IP=203.0.113.42
