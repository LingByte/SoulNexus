{
  "name": "lingecho-desktop",
  "version": "0.2.0",
  "description": "SoulMy 桌面桌宠 — Electron 透明壳，挂载 JS 模版 / embed.js",
  "main": "main.js",
  "author": "SoulNexus",
  "private": true,
  "scripts": {
    "setup": "node scripts/ensure-electron.js",
    "postinstall": "node scripts/ensure-electron.js || true",
    "dev:settings": "vite --config settings-ui/vite.config.ts --port 5174 --strictPort",
    "build:settings": "vite build --config settings-ui/vite.config.ts",
    "dev": "concurrently -k -n settings,electron -c cyan,magenta \"npm run dev:settings\" \"wait-on http://127.0.0.1:5174 && cross-env LINGECHO_SETTINGS_DEV=1 electron . --enable-logging\"",
    "start": "npm run build:settings && electron .",
    "pack": "npm run build:settings && electron-builder --dir",
    "dist": "npm run build:settings && electron-builder",
    "dist:mac": "npm run build:settings && electron-builder --mac",
    "dist:win": "npm run build:settings && electron-builder --win --x64",
    "dist:win:arm64": "npm run build:settings && electron-builder --win --arm64",
    "dist:linux": "npm run build:settings && electron-builder --linux"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "uiohook-napi"
    ]
  },
  "build": {
    "appId": "com.soulnexus.desktop-pet",
    "productName": "SoulMy",
    "copyright": "Copyright © SoulMy",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "coding-hook.js",
      "coding-hook-worker.js",
      "desktop-tidy.js",
      "renderer/**/*",
      "assets/**/*",
      "dist-settings/**/*",
      "package.json",
      "!**/node_modules/uiohook-napi/build/**"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "SoulNexus Desktop ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "SoulNexus"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SoulNexus Desktop"
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  }
}
