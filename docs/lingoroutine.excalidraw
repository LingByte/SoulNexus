    {
      "id": "P-CTDFrBcux7ftOBKvyPj",
      "type": "text",
      "x": -3209.6201956390073,
      "y": 4445.613415436008,
      "width": 250.5438995361328,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
