    {
      "id": "P9Y9OEH2kzRMN73Bv1PLy",
      "type": "text",
      "x": 7381.731000368653,
      "y": 5675.9730721921815,
      "width": 160,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
