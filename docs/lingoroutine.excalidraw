    {
      "id": "aujjr24KmoHRP_u-sX5X2",
      "type": "text",
      "x": 6072.265527348057,
      "y": 4929.915726276291,
      "width": 413.659912109375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
