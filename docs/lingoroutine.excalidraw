      "text": "SYN \n(seq=100)\n随机初始序列号",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "CoPuWWTHCW-Ds67MUEApU",
