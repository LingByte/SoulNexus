      "type": "text",
      "x": -3233.0094542813026,
      "y": 5837.376067817557,
      "width": 416,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLN",
      "roundness": null,
      "seed": 2021833699,
      "version": 50,
      "versionNonce": 535849453,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776236203104,
      "link": null,
      "locked": false,
      "text": "实现复杂，要求客户端和服务器都能够支持多层次的编码。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "实现复杂，要求客户端和服务器都能够支持多层次的编码。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
