      "locked": false,
      "text": "对解码和编码的计算负担较大。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "对解码和编码的计算负担较大。",
