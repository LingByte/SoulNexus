    {
      "id": "aujjr24KmoHRP_u-sX5X2",
      "type": "text",
      "x": 3417.710839848057,
      "y": 7422.220413776291,
      "width": 413.659912109375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
