      "versionNonce": 1539592410,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479420,
      "link": null,
      "locked": false,
      "text": "消除了对中心化服务器的依赖，增强了系统的容错性和隐私性。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "消除了对中心化服务器的依赖，增强了系统的容错性和隐私性。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1K0QTpNowuWXZA7n78PsD",
      "type": "text",
      "x": -3196.356158510152,
      "y": 5380.933210867313,
      "width": 288,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLC",
      "roundness": null,
      "seed": 980145155,
      "version": 139,
      "versionNonce": 1132012954,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479420,
      "link": null,
      "locked": false,
      "text": "无需服务器的媒体转发，可以减少延迟。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "无需服务器的媒体转发，可以减少延迟。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YmbFi6rICisQRu2IZf0Iu",
      "type": "text",
