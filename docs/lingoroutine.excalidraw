    {
      "id": "pxEj12D6sV-4IK25WGYNd",
      "type": "text",
      "x": 3235.439567626273,
      "y": 8809.001876694296,
      "width": 121.73994445800781,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
