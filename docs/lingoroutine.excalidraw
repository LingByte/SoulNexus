      "boundElements": [],
      "updated": 1776677479420,
      "link": null,
      "locked": false,
      "text": "对解码和编码的计算负担较大。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
