      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479419,
      "link": null,
      "locked": false,
      "text": "更容易应对大规模用户同时在线的情况，提升系统的可扩展性。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "更容易应对大规模用户同时在线的情况，提升系统的可扩展性。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9S2h2h7Rhq-aHJncRc1MG",
      "type": "text",
      "x": -3097.610036589242,
