      "isDeleted": false,
      "boundElements": [],
      "updated": 1776236203104,
      "link": null,
      "locked": false,
      "text": "缺点：",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "缺点：",
      "autoResize": true,
      "lineHeight": 1.25
    },
