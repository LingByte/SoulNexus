    {
      "id": "HvF1ciXauyHl70_3GVerz",
      "type": "text",
      "x": 2867.866009876202,
      "y": 9232.975492770403,
      "width": 280,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bTK",
      "roundness": null,
      "seed": 629017571,
      "version": 61,
      "versionNonce": 934212461,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776236254608,
      "link": null,
      "locked": false,
      "text": "超时重传的问题：\n\nRTO通常是100-1000ms\n如果丢包了，要等这么久才重传\n这太慢了！",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "超时重传的问题：\n\nRTO通常是100-1000ms\n如果丢包了，要等这么久才重传\n这太慢了！",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "izhf-g30sZr4hJxHNKKMp",
      "type": "text",
      "x": 2208.5473720405707,
      "y": 10219.725408523402,
      "width": 474.25347900390625,
      "height": 101.47533397430384,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bTL",
      "roundness": null,
      "seed": 641243011,
      "version": 156,
      "versionNonce": 360580579,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776236254608,
      "link": null,
      "locked": false,
      "text": "TCP的快速重传机制\n\n不等超时，收到3个重复ACK就立即重传",
      "fontSize": 27.060089059814356,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TCP的快速重传机制\n\n不等超时，收到3个重复ACK就立即重传",
      "autoResize": true,
      "lineHeight": 1.25
    },
