      "roundness": null,
      "seed": 1109268515,
      "version": 106,
      "versionNonce": 886528346,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479419,
      "link": null,
      "locked": false,
      "text": "优点：",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "优点：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Q1CgyqXw_2qsrnq3oz3BM",
      "type": "text",
      "x": -3251.380495437081,
      "y": 4985.812898998004,
      "width": 416,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bL2",
      "roundness": null,
      "seed": 59579331,
      "version": 106,
      "versionNonce": 102178330,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479419,
      "link": null,
      "locked": false,
      "text": "高度可扩展，可以动态增加服务器容量以应对大规模用户。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "高度可扩展，可以动态增加服务器容量以应对大规模用户。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MIsQAmdpDWWm771Pt9_LQ",
      "type": "text",
      "x": -3235.380495437081,
      "y": 5015.812898998004,
      "width": 384,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bL3",
      "roundness": null,
      "seed": 865774435,
      "version": 106,
      "versionNonce": 1283476186,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479419,
      "link": null,
      "locked": false,
      "text": "可通过云服务商的基础设施来保证高可靠性和容错性。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "可通过云服务商的基础设施来保证高可靠性和容错性。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "O1Ej7x_Ka-BQ62ieanzk-",
      "type": "text",
      "x": -3203.380495437081,
      "y": 5045.812898998004,
      "width": 320,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bL4",
      "roundness": null,
      "seed": 378881795,
