      "versionNonce": 668670426,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479420,
      "link": null,
      "locked": false,
      "text": "实现复杂，要求客户端和服务器都能够支持多层次的编码。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "实现复杂，要求客户端和服务器都能够支持多层次的编码。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
