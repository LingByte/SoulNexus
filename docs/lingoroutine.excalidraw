      "versionNonce": 1856364442,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776677479419,
      "link": null,
      "locked": false,
      "text": "适合大规模的直播、企业级视频会议等应用。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "适合大规模的直播、企业级视频会议等应用。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LiGFAj15jdxK5v2_naixQ",
      "type": "text",
      "x": -3067.380495437081,
      "y": 5075.812898998004,
      "width": 48,
      "height": 20,
