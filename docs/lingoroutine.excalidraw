      "text": "ACK",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7dVmgh2Ym5-1MLpA5rPWB",
      "originalText": "ACK",
      "autoResize": true,
