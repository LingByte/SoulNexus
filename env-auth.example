# ===========================================================================
# SoulNexus Auth / User Service (.env-auth)
# ---------------------------------------------------------------------------
# Loaded by `cmd/auth` from `.env-auth`, then `.env-auth.${APP_ENV|MODE}`.
# Copy:  cp env-auth.example .env-auth
#
# Anything not set here falls back to the process environment, then defaults
# in `internal/config/auth.go` / `internal/config/server.go` (buildGlobalConfig).
#
# cmd/server connects to this process via AUTH_SERVICE_GRPC_ADDR (set in .env-server).
# ===========================================================================

# --- Mode ------------------------------------------------------------------
APP_ENV=development
MODE=development
# SOULNEXUS_SERVICE=auth

# --- HTTP + gRPC listeners (cmd/auth) ----------------------------------------
# HTTP: user registration, login, profile, OIDC, passkeys, etc.
USER_SERVICE_HTTP_ADDR=:7074
# gRPC: credential / user queries for cmd/server
AUTH_GRPC_ADDR=:7075

# --- Server metadata (links in email / OIDC / templates) ---------------------
MACHINE_ID=1
SERVER_NAME=SoulNexus
SERVER_DESC=AI Voice Assistant Platform
SERVER_URL=http://localhost:7072
SERVER_LOGO=
SERVER_TERMS_URL=

# Route prefixes (HTTP API under USER_SERVICE_HTTP_ADDR)
API_PREFIX=/api
AUTH_PREFIX=/auth
DOCS_PREFIX=/api/docs
# ADDR is used by shared config validation; auth HTTP bind uses USER_SERVICE_HTTP_ADDR.
ADDR=:7074

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=info
LOG_FILENAME=./logs/auth.log
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=5
LOG_DAILY=true

# ---------------------------------------------------------------------------
# 1) Database (same schema as cmd/server until split)
# ---------------------------------------------------------------------------
DB_DRIVER=sqlite
DSN=./ling.db

# PostgreSQL (production)
# DB_DRIVER=postgres
# DSN=postgres://lingecho:your-password@localhost:5432/lingecho?sslmode=disable

# MySQL
# DB_DRIVER=mysql
# DSN=lingecho:your-password@tcp(localhost:3306)/lingecho?charset=utf8mb4&parseTime=True&loc=Local

# ---------------------------------------------------------------------------
# 2) Session, API signing, JWT
# ---------------------------------------------------------------------------
SESSION_SECRET=change-me-in-production
SESSION_EXPIRE_DAYS=7
# SESSION_COOKIE_SECURE=false          # local HTTP dev
# SESSION_SAMESITE=lax                 # lax | strict | none

API_SECRET_KEY=change-me-in-production

# JWT access/refresh (default RS256 + JWKS file)
JWT_ALGORITHM=RS256
JWT_KEY_FILE=./keys/jwks.json
JWT_ROTATION_DAYS=30
JWT_KEEP_OLD_KEYS=2
# REFRESH_TOKEN_EXPIRED=30d

# ---------------------------------------------------------------------------
# 3) Browser security & login hardening
# ---------------------------------------------------------------------------
# HTTP_CSP=
# HTTP_HSTS_DISABLED=true
# TRUSTED_BROWSER_ORIGINS=http://localhost:5173,http://localhost:7074
# TRUSTED_ORIGIN_CHECK_SKIP_PREFIXES=/api/custom/webhook/

LOGIN_CAPTCHA_DISABLED=false
# LOGIN_IP_RATE_MAX_ATTEMPTS=30
# ACCOUNT_DELETION_COOLDOWN_HOURS=72

# ---------------------------------------------------------------------------
# 4) OIDC (subsystem token exchange)
# ---------------------------------------------------------------------------
OIDC_CLIENT_ID=soulnexus-web
OIDC_CLIENT_SECRET=replace-with-strong-secret

# ---------------------------------------------------------------------------
# 5) OAuth / social login (optional)
# ---------------------------------------------------------------------------
# GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=

# WeChat mini program / MP
# WECHAT_MP_APP_ID=
# WECHAT_MP_SECRET=
# WECHAT_MP_TOKEN=
# WECHAT_MP_AES_KEY=
# WECHAT_OAUTH_REDIRECT_URI=
# WECHAT_LOGIN_BIND_EMAIL=

# ---------------------------------------------------------------------------
# 6) WebAuthn / passkeys (optional)
# ---------------------------------------------------------------------------
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_ORIGINS=http://localhost:5173,http://localhost:7074
# WEBAUTHN_RP_DISPLAY_NAME=SoulNexus

# ---------------------------------------------------------------------------
# 7) Cache
# ---------------------------------------------------------------------------
CACHE_TYPE=local
# CACHE_TYPE=redis
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_POOL_SIZE=10
# REDIS_MIN_IDLE_CONNS=5
# LOCAL_CACHE_MAX_SIZE=1000
# LOCAL_CACHE_DEFAULT_EXPIRATION=5m
# LOCAL_CACHE_CLEANUP_INTERVAL=10m

# ---------------------------------------------------------------------------
# 8) Static assets (login pages, captcha, etc.)
# ---------------------------------------------------------------------------
STATIC_PREFIX=/static
STATIC_ROOT=./static
UPLOAD_DIR=./uploads

# ---------------------------------------------------------------------------
# 9) Gateway middleware (rate limit, timeout, circuit breaker)
# ---------------------------------------------------------------------------
ENABLE_RATE_LIMIT=true
ENABLE_TIMEOUT=true
ENABLE_CIRCUIT_BREAKER=false
ENABLE_OPERATION_LOG=true
DEFAULT_TIMEOUT=60s

# RATE_LIMIT_GLOBAL_RPS=10000
# RATE_LIMIT_GLOBAL_BURST=20000
# RATE_LIMIT_USER_RPS=1000
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=10

# ---------------------------------------------------------------------------
# 10) Features
# ---------------------------------------------------------------------------
LANGUAGE_ENABLED=true
SEARCH_ENABLED=false
BACKUP_ENABLED=false

# ---------------------------------------------------------------------------
# 11) SSL/TLS (optional HTTPS on USER_SERVICE_HTTP_ADDR)
# ---------------------------------------------------------------------------
SSL_ENABLED=false
# SSL_CERT_FILE=./ssl/cert.pem
# SSL_KEY_FILE=./ssl/key.pem

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# LoadModuleEnvs only reads .env-auth* — root .env is NOT auto-loaded.
# Pair with .env-server on the API host:
#   AUTH_SERVICE_GRPC_ADDR=127.0.0.1:7075
