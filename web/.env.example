# API配置
# 后端API基础地址（必需）
VITE_API_BASE_URL=http://localhost:7072/api
VITE_USER_SERVICE_BASE_URL=http://localhost:7074/api

# WebSocket基础地址（可选，如果不设置会自动从API地址转换）
# VITE_WS_BASE_URL=ws://localhost:7072

# 上传文件基础地址（可选，如果不设置会自动从API地址转换）
# VITE_UPLOADS_BASE_URL=http://localhost:7072/uploads

# SSO/OIDC 配置
# 登录跳转地址（点击登录会跳转到这里）
VITE_SSO_LOGIN_URL=https://sso.lingecho.com/api/auth/login
# 标准 OIDC 授权地址（配置后优先使用）
# VITE_SSO_AUTHORIZE_URL=https://sso.lingecho.com/api/auth/oidc/authorize
# 换取 token 地址（code 回调后会调用）
VITE_SSO_TOKEN_URL=https://sso.lingecho.com/api/auth/oidc/token
# SSO 退出地址（用于清理 SSO 会话）
# VITE_SSO_LOGOUT_URL=https://sso.lingecho.com/api/auth/logout
# 当前 web 客户端在 SSO 侧登记的 client_id
VITE_OIDC_CLIENT_ID=soulnexus-web
