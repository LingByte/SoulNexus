# API配置
# 后端API基础地址（必需）
VITE_API_BASE_URL=http://localhost:7072/api

# Web 坐席（SIP 网关 cmd/sip 的 SIP_WEBSEAT_HTTP_ADDR / SIP_WEBSEAT_WS_TOKEN）
# 登录后自动连接 WebSocket 来电推送；未配置则云联络中心「Web 坐席」页提示说明
# VITE_SIP_WEBSEAT_HTTP_BASE=http://your-server-host:9080
# 可选：给 WebSocket 单独前缀（例如反代到 /ws），不填则沿用 HTTP_BASE
# VITE_SIP_WEBSEAT_WS_BASE=https://your-domain/ws
# VITE_SIP_WEBSEAT_WS_TOKEN=

# WebSocket基础地址（可选，如果不设置会自动从API地址转换）
# VITE_WS_BASE_URL=ws://localhost:7072

# 上传文件基础地址（可选，如果不设置会自动从API地址转换）
# VITE_UPLOADS_BASE_URL=http://localhost:7072/uploads
