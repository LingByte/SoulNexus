# API配置
# 后端API基础地址（必需）
VITE_API_BASE_URL=http://localhost:7072/api


# cmd/voice 的 -http 访问前缀，可带反向代理路径前缀
VITE_CMD_VOICE_BASE=http://127.0.0.1:7080/cmd-voice

# WebSocket基础地址（可选，如果不设置会自动从API地址转换）
# VITE_WS_BASE_URL=ws://localhost:7072

# SSO Config
VITE_USER_SERVICE_BASE_URL=https://sso.xxx.com/api
# SSO/OIDC 配置
# 登录跳转地址（点击登录会跳转到这里）
VITE_SSO_LOGIN_URL=https://sso.xxx.com/api/auth/login
# 标准 OIDC 授权地址（配置后优先使用）
VITE_SSO_AUTHORIZE_URL=https://sso.xxx.com/api/auth/oidc/authorize
# 子系统后端中转换 token 地址（前端回调后调用）
VITE_SSO_EXCHANGE_URL=https://sso.xxx.com/api/auth/oidc/exchange
# SSO 退出地址（用于清理 SSO 会话）
VITE_SSO_LOGOUT_URL=https://sso.xxx.com/api/auth/logout
# 当前 web 客户端在 SSO 侧登记的 client_id
VITE_OIDC_CLIENT_ID=soulnexus-web
