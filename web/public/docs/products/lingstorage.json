    {
      "id": "api-examples",
      "title": "API Examples",
      "subsections": [
        {
          "title": "Upload File",
          "description": "Upload a file to LingStorage",
          "details": [
            "POST /api/v1/upload",
            "Content-Type: multipart/form-data",
            "Authentication: Bearer {token}",
            "Response: { url, size, hash, timestamp }"
          ]
        },
        {
          "title": "Download File",
          "description": "Download a file from LingStorage",
          "details": [
            "GET /api/v1/files/{fileId}",
            "Query params: download=true",
            "Authentication: Bearer {token}",
            "Response: File binary data"
          ]
        },
        {
          "title": "List Files",
          "description": "List files in a bucket",
          "details": [
            "GET /api/v1/buckets/{bucketId}/files",
            "Query params: limit, offset, prefix",
            "Authentication: Bearer {token}",
            "Response: Array of file objects"
          ]
        },
        {
          "title": "Delete File",
          "description": "Delete a file from storage",
          "details": [
            "DELETE /api/v1/files/{fileId}",
            "Authentication: Bearer {token}",
            "Response: { success, message }"
          ]
        }
      ]
    },
